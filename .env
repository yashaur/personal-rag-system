# Backend configuration — consumed by app/config.py (Pydantic BaseSettings).
# Values here mirror the defaults in config.py; override per machine as needed.

# --- Ollama (LLM + embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=ministral-3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.0

# --- Chroma vector store ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=personal_rag

# --- Chunking (RecursiveCharacterTextSplitter) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
TOP_K=5
RERANK_TOP_N=3
HYBRID_WEIGHTS=[0.6, 0.4]
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Local data directories ---
BM25_DIR=./data/bm25
UPLOADS_DIR=./data/uploads
