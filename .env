# Backend configuration — consumed by app/config.py (Pydantic BaseSettings).
# Values here mirror the defaults in config.py; override per machine as needed.

# --- Ollama (LLM + embeddings) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=llama3.2:3b
OLLAMA_CONDENSER_MODEL=ministral-3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
LLM_TEMPERATURE=0.0

# --- Chroma vector store ---
CHROMA_DIR=./data/chroma
COLLECTION_NAME=personal_rag

# --- Chunking (RecursiveCharacterTextSplitter) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# --- Retrieval ---
TOP_K=10
RERANK_TOP_N=8
HYBRID_WEIGHTS=[0.7, 0.3]
RERANKER_MODEL=BAAI/bge-reranker-base

# --- Local data directories ---
BM25_DIR=./data/bm25
UPLOADS_DIR=./data/uploads

# --- Langfuse environment variables ---
LANGFUSE_SECRET_KEY="sk-lf-a127b055-2d81-4b54-9b15-f6820641a018"
LANGFUSE_PUBLIC_KEY="pk-lf-306e5555-dd82-47fd-8879-9f9bb12a33e7"
LANGFUSE_BASE_URL="http://localhost:3000"